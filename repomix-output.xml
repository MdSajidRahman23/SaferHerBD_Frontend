class ServiceConfig {
  // ── Maps ────────────────────────────────────────────────────────
  // Free  : OpenStreetMap (no key needed)        ← default
  // Paid  : Google Maps                          ← needs API key
  static const String googleMapsApiKey = '';   // ← paste your key here when ready
