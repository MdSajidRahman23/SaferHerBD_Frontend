# SafeHerBD Flutter gitignore

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
Thumbs.db
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ / Android Studio / VS Code
*.iml
*.ipr
*.iws
.idea/
.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
coverage/

# Native generated files
android/local.properties
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
android/app/debug/
android/app/profile/
android/app/release/

# Symbols / obfuscation
app.*.symbols
app.*.map.json

# Environment / secrets
.env
.env.*
!.env.example
firebase-credentials.json
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Backups / patch artifacts / generated reports
*.backup_*
*.bak
*.old
*_backup*
_safeher_backups/
_safeher_reports/
_safeher_tools/
FRONTEND_P*_README.txt
SAFEHERBD_P*_README.txt
safeher_patch/
safeher_sprint*_patch/

# Repomix / generated source dumps
repomix-output.xml
*-output.xml
*_output.xml

# Local SafeHer patch/backup artifacts
_safeher_backups/
_safeher_reports/
_safeher_tools/
*.backup*
